{
  "name": "smart-wallet-tests",
  "version": "1.0.0",
  "description": "Run unit tests on this project.",
  "type": "module",
  "private": true,
  "scripts": {
    "test": "vitest run",
    "test:report": "vitest run -- --coverage --costs",
    "test:watch": "chokidar \"tests/**/*.ts\" \"contracts/**/*.clar\" -c \"npm run test:report\"",
    "generate": "clarigen generate",
    "update:ui": "cp ./contracts/smart-wallet-standard.clar ./../ui/public/smart-wallet.clar"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@clarigen/cli": "4.1.3",
    "@stacks/clarinet-sdk": "^3.16.0",
    "@stacks/clarinet-sdk-wasm": "^3.16.0",
    "@stacks/clarunit": "friedger/stacks-test-tools#18fda2be121b4884968c34b4fd56c1ffe2555281",
    "@stacks/rendezvous": "0.14.0",
    "@stacks/stacking": "^7.3.0",
    "@stacks/transactions": "^7.3.0",
    "@vitest/expect": "^4.0.15",
    "chokidar-cli": "^3.0.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "vitest-environment-clarinet": "^3.0.2"
  },
  "devDependencies": {
    "@clarigen/core": "4.1.3",
    "@clarigen/test": "4.1.3",
    "@noble/curves": "^2.2.0",
    "fast-check": "^4.4.0"
  }
}
